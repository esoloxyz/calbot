# --- Telegram ---
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_ID=-1001234567890        # your private group's ID (use /id in the group)
ALLOWED_USER_IDS=                     # optional comma-separated Telegram user IDs

# --- Claude ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Google Calendar ---
GOOGLE_SERVICE_ACCOUNT_JSON=
CALENDAR_ID=yoursharedaccount@gmail.com   # or the calendar's ID from its settings page

# --- Tempo ---
TEMPO_WALLET_STORE_B64=         # base64-encoded contents of ~/.tempo/wallet/store.json
TEMPO_AUTO_SPEND=0.01           # default cap; max 6 decimal places; approval still required
TEMPO_MAX_SPEND=0.50            # absolute approved-call ceiling; max 6 decimal places
TEMPO_BIN=                      # optional; defaults to ~/.tempo/bin/tempo
TEMPO_HOME=                     # optional launcher/extension home; wallet remains ~/.tempo/wallet
TEMPO_RPC_URL=                  # optional HTTPS override for all-token balance reads

# --- Preferences ---
TIMEZONE=America/New_York
BOT_OWNER=Your Name                   # name used in the bot's personality
RESPOND_TO_ALL=true                   # set false to only respond to @mentions / replies
