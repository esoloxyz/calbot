# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-from-botfather
ALLOWED_CHAT_ID=-1001234567890        # your private group's ID (use /id in the group)

# --- Claude ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Google Calendar ---
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ... entire JSON key on one line ...}
CALENDAR_ID=yoursharedaccount@gmail.com   # or the calendar's ID from its settings page

# --- Tempo ---
TEMPO_KEYS_TOML_B64=            # base64-encoded contents of ~/.tempo/wallet/keys.toml

# --- Preferences ---
TIMEZONE=America/New_York
BOT_OWNER=Ezra                        # your name (used in the bot's personality)
RESPOND_TO_ALL=true                   # set false to only respond to @mentions / replies
